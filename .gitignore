# NPD Planner — .gitignore

# ─────────────────────────────────────────
# CRITICAL — NEVER COMMIT THESE
# ─────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ─────────────────────────────────────────
# Dependencies
# ─────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─────────────────────────────────────────
# Build outputs
# ─────────────────────────────────────────
dist/
dist-electron/
out/
build/
release/

# ─────────────────────────────────────────
# Electron build artifacts
# ─────────────────────────────────────────
*.exe
*.dmg
*.AppImage
*.deb
*.rpm
*.snap

# ─────────────────────────────────────────
# Local test builds
# ─────────────────────────────────────────
test-app/
test-app-new/

# ─────────────────────────────────────────
# Logs
# ─────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ─────────────────────────────────────────
# OS files
# ─────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─────────────────────────────────────────
# Editor files
# ─────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ─────────────────────────────────────────
# TypeScript
# ─────────────────────────────────────────
*.tsbuildinfo

# ─────────────────────────────────────────
# Testing
# ─────────────────────────────────────────
coverage/
.nyc_output/

# ─────────────────────────────────────────
# Cache
# ─────────────────────────────────────────
.cache/
.eslintcache
.vite/
.chromium-bundle
