// firestore.rules
// Deploy with: firebase deploy --only firestore:rules
// These rules are the security backbone of NPD Planner
// Test rules at: https://firebase.google.com/docs/rules/unit-tests

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────
    // HELPER FUNCTIONS
    // ─────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isEliteFlowerEmail() {
      return request.auth.token.email.matches('.*@eliteflower\\.com$');
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Domain enforcement happens at REGISTRATION (users create rule) plus the
    // admin approval flow. Requiring @eliteflower.com here too locked out
    // pre-existing accounts on other domains (e.g. the original owner account)
    // from every read in the app the moment these rules were deployed.
    function isActiveUser() {
      return isAuthenticated() &&
             getUserData().status == 'active';
    }

    // isSelf: the authenticated user is operating on their own document
    function isSelf(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // isAppOwner: user has the top-level owner role
    function isAppOwner() {
      return isActiveUser() && getUserData().role == 'owner';
    }

    // isAdmin: owner OR admin (owner has all admin powers)
    function isAdmin() {
      return isActiveUser() &&
             (getUserData().role == 'admin' || getUserData().role == 'owner');
    }

    // ── Founder model (settings/platform.founderUid) ─────────────────────
    // Exactly one founder. Only the founder mints/demotes owners and only
    // the founder can transfer founder status. When the platform doc does
    // not exist yet (bootstrap), nobody has founder powers.
    function platformExists() {
      return exists(/databases/$(database)/documents/settings/platform);
    }
    function founderUidOrEmpty() {
      return platformExists()
        ? get(/databases/$(database)/documents/settings/platform).data.founderUid
        : '';
    }
    function isFounder() {
      return isActiveUser() && platformExists() &&
             get(/databases/$(database)/documents/settings/platform).data.founderUid == request.auth.uid;
    }

    // ── Team isolation ───────────────────────────────────────────────────
    // Membership docs use the deterministic id {teamId}_{uid}, so a single
    // exists() proves membership without a query.
    function isTeamMemberSrv(teamId) {
      return exists(/databases/$(database)/documents/teamMembers/$(teamId + '_' + request.auth.uid));
    }
    function teamRoleSrv(teamId) {
      return get(/databases/$(database)/documents/teamMembers/$(teamId + '_' + request.auth.uid)).data.teamRole;
    }
    // Request visibility: NPD, the creator, assigned managers/helpers, and
    // members of the owning team. Nobody outside the team — full isolation.
    function requestVisible(r) {
      return isAdmin() ||
             (isActiveUser() &&
              (r.createdBy == request.auth.uid ||
               request.auth.uid in r.assignedManagers ||
               request.auth.uid in r.helpers ||
               isTeamMemberSrv(r.teamId)));
    }

    // ── Area/board permission enforcement ────────────────────────────────
    // The Access Permissions UI (None/View/Edit per board and module) used to
    // be cosmetic — these helpers make the server enforce it. Missing fields
    // default safely via Map.get().
    function userPerms() {
      return getUserData().get('areaPermissions', {});
    }
    function canViewBoardSrv(boardId) {
      return isAdmin() ||
             (isActiveUser() && userPerms().get('board_' + boardId, 'none') in ['view', 'edit']);
    }
    function canEditBoardSrv(boardId) {
      return isAdmin() ||
             (isActiveUser() && userPerms().get('board_' + boardId, 'none') == 'edit');
    }
    function isPhotographerUser() {
      return isActiveUser() &&
             (getUserData().role == 'photographer' ||
              getUserData().get('isPhotographer', false) == true);
    }
    // npd_projects with legacy key aliases (elitequote, recipes)
    function npdLevel() {
      return userPerms().get('npd_projects',
             userPerms().get('elitequote',
             userPerms().get('recipes', 'none')));
    }
    function canViewNpd() {
      return isAdmin() || isPhotographerUser() ||
             (isActiveUser() && npdLevel() in ['view', 'edit']);
    }
    function canEditNpd() {
      return isAdmin() || isPhotographerUser() ||
             (isActiveUser() && npdLevel() == 'edit');
    }

    // ─────────────────────────────────────────
    // USERS
    // ─────────────────────────────────────────

    match /users/{uid} {
      // Active users can read all user docs (for @mentions, assignee picker)
      // Any authenticated user can read their own doc (needed to check status on login)
      allow read: if isActiveUser() || (isAuthenticated() && isSelf(uid));

      // New user can create their own document:
      //   - Normal registration: awaiting + member
      //   - First user bootstrap: active + owner (client checks hasAnyAdmin first)
      allow create: if isAuthenticated() &&
                       isEliteFlowerEmail() &&
                       isSelf(uid) &&
                       (
                         (request.resource.data.status == 'awaiting' &&
                          request.resource.data.role == 'member') ||
                         (request.resource.data.status == 'active' &&
                          request.resource.data.role == 'owner')
                       );

      // Founder can update anyone (the only one who manages owners).
      // Owner can update anyone EXCEPT the founder and except touching the
      // owner role in any direction — minting/demoting owners is founder-only.
      // Admin can manage members but can NEVER mint admins or owners.
      // Users can update their own non-sensitive preferences.
      // Emergency recovery: self-promotion to owner requires a server-verified
      // emergency unlock (see /emergencyUnlocks — proof of the master key)
      allow update: if isFounder() ||
                       (isAppOwner() &&
                        uid != founderUidOrEmpty() &&
                        resource.data.role != 'owner' &&
                        request.resource.data.role != 'owner') ||
                       (isAdmin() &&
                        resource.data.role == 'member' &&
                        request.resource.data.role != 'owner' &&
                        request.resource.data.role != 'admin') ||
                       (isSelf(uid) &&
                        !request.resource.data.diff(resource.data)
                          .affectedKeys()
                          .hasAny(['role', 'status', 'email', 'uid', 'areaPermissions'])) ||
                       (isSelf(uid) &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role']) &&
                        request.resource.data.role == 'owner' &&
                        exists(/databases/$(database)/documents/emergencyUnlocks/$(request.auth.uid)));

      // Founder can delete anyone; owners can delete non-owners only.
      // The founder's doc can never be deleted by someone else.
      allow delete: if isFounder() ||
                       (isAppOwner() &&
                        uid != founderUidOrEmpty() &&
                        resource.data.role != 'owner');
    }

    // ─────────────────────────────────────────
    // BOARDS
    // ─────────────────────────────────────────

    match /boards/{boardId} {
      allow read: if isActiveUser();
      allow create, update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────
    // TASKS
    // ─────────────────────────────────────────

    match /tasks/{taskId} {
      // Board access enforced server-side: View can read, Edit can write.
      // Assignees can always READ their own tasks (My Tasks spans boards).
      allow read: if isActiveUser() &&
                     (canViewBoardSrv(resource.data.boardId) ||
                      request.auth.uid in resource.data.get('assignees', []));
      // Board editors create tasks normally. Sales people of a team may also
      // create the linked task that accompanies their sample request — the
      // task must carry their own team in sourceTeamId.
      allow create: if canEditBoardSrv(request.resource.data.boardId) ||
                       (isActiveUser() &&
                        request.resource.data.get('sourceTeamId', '') != '' &&
                        isTeamMemberSrv(request.resource.data.sourceTeamId) &&
                        teamRoleSrv(request.resource.data.sourceTeamId) == 'sales');
      // Both the current board and the target board (task moves) need Edit
      allow update: if canEditBoardSrv(resource.data.boardId) &&
                       canEditBoardSrv(request.resource.data.boardId);
      // Only the task creator (with board Edit) or an admin can delete
      allow delete: if isAdmin() ||
                       (resource.data.createdBy == request.auth.uid &&
                        canEditBoardSrv(resource.data.boardId));
    }

    // ─────────────────────────────────────────
    // CLIENTS
    // ─────────────────────────────────────────

    match /clients/{clientId} {
      allow read: if isActiveUser();
      // Create stays open — tasks offer inline "+ New Client"
      allow create: if isActiveUser();
      // Renaming/deactivating clients affects every task — admins only
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────
    // DIVISIONS
    // ─────────────────────────────────────────

    match /divisions/{divisionId} {
      allow read: if isActiveUser();
      allow write: if isActiveUser();
    }

    // ─────────────────────────────────────────
    // LABELS
    // ─────────────────────────────────────────

    match /labels/{labelId} {
      allow read: if isActiveUser();
      // Only admins can create/edit/delete labels
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────
    // COMMENTS
    // ─────────────────────────────────────────

    match /comments/{commentId} {
      allow read: if isActiveUser();
      allow create: if isActiveUser();

      // Users can only edit/delete their own comments
      allow update: if isActiveUser() &&
                       resource.data.authorId == request.auth.uid;
      allow delete: if isActiveUser() &&
                       resource.data.authorId == request.auth.uid ||
                       isAdmin();
    }

    // ─────────────────────────────────────────
    // TASK HISTORY (append-only — never modified)
    // ─────────────────────────────────────────

    match /taskHistory/{historyId} {
      allow read: if isActiveUser();
      allow create: if isActiveUser();
      // History is immutable — no updates or deletes ever
      allow update, delete: if false;
    }

    // ─────────────────────────────────────────
    // NOTIFICATIONS
    // ─────────────────────────────────────────

    match /notifications/{notifId} {
      // Users can only read their own notifications
      allow read: if isActiveUser() &&
                     resource.data.userId == request.auth.uid;

      // Any active user can create notifications for others, but the sender
      // identity can't be spoofed — triggeredBy must be the caller (or the
      // literal 'system', used by automated Traze alerts)
      allow create: if isActiveUser() &&
                       (request.resource.data.get('triggeredBy', '') == request.auth.uid ||
                        request.resource.data.get('triggeredBy', '') == 'system');

      // Users can only mark their own notifications as read
      allow update: if isActiveUser() &&
                       resource.data.userId == request.auth.uid &&
                       request.resource.data.diff(resource.data)
                         .affectedKeys()
                         .hasOnly(['read']);

      // Users may delete their own notifications (the app prunes read
      // notifications older than 30 days — the collection grew unbounded)
      allow delete: if isActiveUser() &&
                       resource.data.userId == request.auth.uid;
    }

    // ─────────────────────────────────────────
    // ARCHIVE (annual summaries)
    // ─────────────────────────────────────────

    match /archive/{archiveId} {
      allow read: if isActiveUser();
      // Only admins can generate and save archive summaries
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────
    // SETTINGS
    // ─────────────────────────────────────────

    match /settings/{docId} {
      // The emergency master key hash must NEVER be client-readable — rules
      // compare against it server-side (see /emergencyUnlocks below)
      allow read: if isActiveUser() && docId != 'emergency';
      // Only admins can change global settings; 'emergency' is owner-only and
      // 'platform' (founder governance) has its own match below
      allow write: if isAdmin() && docId != 'emergency' && docId != 'platform';
    }

    match /settings/emergency {
      allow read: if false;
      allow write: if isAppOwner();
    }

    // Founder governance doc — see Founder model helpers above.
    //   create → bootstrap: an owner claims founder while no founder exists
    //   update → legacy transfer by the current founder (target must be a real
    //            user), or emergency recovery via server-verified master key
    match /settings/platform {
      allow read: if isActiveUser();
      allow create: if isAppOwner() &&
                       request.resource.data.founderUid == request.auth.uid;
      allow update: if (isFounder() &&
                        exists(/databases/$(database)/documents/users/$(request.resource.data.founderUid))) ||
                       (isActiveUser() &&
                        request.resource.data.founderUid == request.auth.uid &&
                        exists(/databases/$(database)/documents/emergencyUnlocks/$(request.auth.uid)));
      allow delete: if false;
    }

    // ─────────────────────────────────────────
    // EMERGENCY UNLOCKS (server-verified master key proof)
    // Writing here succeeds ONLY when the submitted hash matches the stored
    // master key hash — which clients can never read. An unlock doc is the
    // prerequisite for the self-promotion-to-owner rule on /users.
    // ─────────────────────────────────────────

    match /emergencyUnlocks/{uid} {
      allow read: if false;
      allow create, update: if isSelf(uid) &&
        request.resource.data.keys().hasOnly(['keyHash', 'unlockedAt']) &&
        request.resource.data.keyHash ==
          get(/databases/$(database)/documents/settings/emergency).data.masterKeyHash;
      allow delete: if isAppOwner();
    }

    // appBootstrap is publicly readable so registration can check if an owner exists
    // without requiring authentication (new users are not yet logged in at that point).
    match /settings/appBootstrap {
      allow read: if true;
      // First-time bootstrap: allow any authenticated @eliteflower.com user to create it
      // (prevents outsiders from claiming first-admin if document is accidentally deleted)
      allow write: if isAdmin() ||
                      (isAuthenticated() && isEliteFlowerEmail() &&
                       !exists(/databases/$(database)/documents/settings/appBootstrap));
    }

    // ─────────────────────────────────────────
    // USER PRIVATE (personal space - only owner can access)
    // ─────────────────────────────────────────

    match /userPrivate/{userId}/{document=**} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // ─────────────────────────────────────────
    // RECIPE MANAGER
    // ─────────────────────────────────────────

    // Access requires the npd_projects area permission (or admin/photographer)
    // — previously any active user could read AND write every recipe even with
    // "NPD Projects: None" in the Access Permissions UI.
    match /recipeProjects/{projectId} {
      allow read: if canViewNpd();
      allow write: if canEditNpd();

      match /recipeFiles/{fileId} {
        allow read: if canViewNpd();
        allow write: if canEditNpd();

        // Notes — any NPD viewer can post; only author or admin can delete
        match /notes/{noteId} {
          allow read:   if canViewNpd();
          allow create: if canViewNpd();
          // Notes are immutable — no edits allowed
          allow update: if false;
          allow delete: if canViewNpd() &&
                           (resource.data.authorId == request.auth.uid || isAdmin());
        }
      }

      match /recipePresence/{userId} {
        allow read: if canViewNpd();
        allow write: if canViewNpd() && (request.auth.uid == userId || isAdmin());
      }

      match /settings/{settingsDoc} {
        allow read: if canViewNpd();
        allow write: if isAdmin();
      }

      match /activity/{eventId} {
        allow read, create: if canViewNpd();
        allow update, delete: if false;
      }
    }

    match /recipeSettings/{userId} {
      allow read, write: if request.auth.uid == userId || isAdmin();
    }

    // ─────────────────────────────────────────
    // TRASH QUEUE (soft delete with recovery)
    // ─────────────────────────────────────────

    match /trashQueue/{trashId} {
      // Members enqueue their own deletions (the task delete flow); only
      // admins see and manage the trash (restore, purge, schedule)
      allow create: if isActiveUser();
      allow read, update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────
    // HISTORICAL TASKS (Microsoft Planner import)
    // ─────────────────────────────────────────

    match /historicalTasks/{taskId} {
      allow read: if isActiveUser();
      allow write: if isAdmin();
    }

    match /importBatches/{batchId} {
      allow read: if isActiveUser();
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────
    // DATE TYPES (calendar event type definitions)
    // ─────────────────────────────────────────

    match /dateTypes/{dateTypeId} {
      allow read: if isActiveUser();
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────
    // PENDING APPROVALS (new user queue)
    // ─────────────────────────────────────────

    match /pendingApprovals/{uid} {
      // Only admins/owners can read the approval queue
      allow read:   if isAdmin();
      // A newly registered user (not yet active) can create their own pending doc
      allow create: if isAuthenticated() && request.auth.uid == uid;
      // Admins can update reviewingBy lock and process approvals
      allow update: if isAdmin();
      // Admins can delete after approving or rejecting
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────
    // CRASH REPORTS (ephemeral — write by any active user, delete by admin)
    // Flow: renderer saves → notifies owners → admin reads → doc deleted immediately
    // ─────────────────────────────────────────

    match /crashReports/{reportId} {
      // Any active user can submit a crash report
      allow create: if isActiveUser();
      // Owners/admins can read reports (for in-app notification flow)
      allow read: if isAdmin();
      // Only admins can delete (the notification handler deletes after reading)
      allow delete: if isAdmin();
      // Reports are immutable — no updates
      allow update: if false;
    }

    // ─────────────────────────────────────────
    // TEAMS (multi-team platform — full isolation)
    // ─────────────────────────────────────────
    // A team only sees itself. NPD admins/owners see and manage everything.
    // Membership management is admin-only in Fase 1.

    match /teams/{teamId} {
      allow read: if isAdmin() ||
                     (isActiveUser() && isTeamMemberSrv(teamId));
      allow create, update, delete: if isAdmin();
    }

    match /teamMembers/{membershipId} {
      // Readable by: admins, the member themself (My Teams), and fellow
      // members of the same team (roster view). Never across teams.
      allow read: if isAdmin() ||
                     (isActiveUser() &&
                      (resource.data.uid == request.auth.uid ||
                       isTeamMemberSrv(resource.data.teamId)));
      allow create, update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────
    // SAMPLE REQUESTS (teams → NPD pipeline)
    // ─────────────────────────────────────────

    match /sampleRequests/{requestId} {
      allow read: if requestVisible(resource.data);

      // Only sales of the owning team file requests (NPD can too). The
      // creator can't impersonate and every request starts at 'submitted'.
      allow create: if isAdmin() ||
                       (isActiveUser() &&
                        request.resource.data.createdBy == request.auth.uid &&
                        request.resource.data.status == 'submitted' &&
                        isTeamMemberSrv(request.resource.data.teamId) &&
                        teamRoleSrv(request.resource.data.teamId) == 'sales');

      // NPD fixes anything. Account managers (of the team, or directly
      // assigned) drive logistics + status. The creator edits core fields
      // only while the request is still 'submitted'.
      allow update: if isAdmin() ||
                       (isActiveUser() &&
                        (request.auth.uid in resource.data.assignedManagers ||
                         (isTeamMemberSrv(resource.data.teamId) &&
                          teamRoleSrv(resource.data.teamId) == 'account_manager')) &&
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['orderNumber', 'farmInfo', 'awbNumber', 'eta', 'status', 'updatedAt', 'updatedBy'])) ||
                       (isActiveUser() &&
                        resource.data.createdBy == request.auth.uid &&
                        resource.data.status == 'submitted' &&
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['title', 'description', 'bucket', 'needByDate', 'shipDate', 'updatedAt', 'updatedBy']));

      allow delete: if isAdmin();

      // Follow-up timeline — append-only, same audience as the request.
      // getAfter() covers the creation batch (request + task + first event).
      match /events/{eventId} {
        allow read: if requestVisible(get(/databases/$(database)/documents/sampleRequests/$(requestId)).data);
        allow create: if requestVisible(getAfter(/databases/$(database)/documents/sampleRequests/$(requestId)).data);
        allow update, delete: if false;
      }

      // Comments — anyone who can see the request can comment; no author
      // spoofing; immutable except author/admin delete.
      match /comments/{commentId} {
        allow read: if requestVisible(get(/databases/$(database)/documents/sampleRequests/$(requestId)).data);
        allow create: if requestVisible(get(/databases/$(database)/documents/sampleRequests/$(requestId)).data) &&
                         request.resource.data.authorId == request.auth.uid;
        allow update: if false;
        allow delete: if isAdmin() ||
                         (isActiveUser() && resource.data.authorId == request.auth.uid);
      }
    }

    // ─────────────────────────────────────────
    // DIRECTORY MODULE
    // ─────────────────────────────────────────

    match /directoryContacts/{contactId} {
      allow read: if isActiveUser();
      allow create, update: if isActiveUser();
      allow delete: if isAdmin();
    }

    match /directorySettings/{docId} {
      allow read: if isActiveUser();
      // Only admins can define/edit custom column schemas
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────
    // DENY ALL OTHER PATHS
    // ─────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
